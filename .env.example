# ─────────────────────────────────────────────────────────────
#  F.R.I.D.A.Y — переменные окружения (пример)
#  Скопируй нужные блоки в apps/web/.env.local (и позже apps/bot/.env)
# ─────────────────────────────────────────────────────────────

# ── Supabase (БД + авторизация) ──────────────────────────────
# Берётся в Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role — секретный ключ, только для сервера/бота, НЕ публиковать
SUPABASE_SERVICE_ROLE_KEY=

# ── Claude — движок FRIDAY (этап 2) ──────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Прочее ───────────────────────────────────────────────────
# Email супер-админа (владельца проекта)
OWNER_EMAIL=vffv347@gmail.com
