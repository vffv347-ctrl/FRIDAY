# Скопируй в apps/bot/.env и заполни.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ключ Claude — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Telegram ID владельца — бот отвечает ТОЛЬКО ему (узнать у @userinfobot)
OWNER_TELEGRAM_ID=

# Ключ OpenAI — для распознавания голосовых сообщений (Whisper).
# Необязательный: без него бот работает, но не слушает голос.
OPENAI_API_KEY=

# Supabase — долговременная память бота.
# SUPABASE_SECRET_KEY — секретный ключ (sb_secret_...), только для сервера.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
